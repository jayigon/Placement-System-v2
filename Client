local function draggingGifts(actionName, inputState, inputObject)
	if inputState == Enum.UserInputState.Begin then
		if UserInputService:IsKeyDown(Enum.KeyCode.H) then
			if not enableDraggingSystem then
				local function draggingRenderStep()
					if arePartsSelected and OBBPart then
						local mouseLocation = UserInputService:GetMouseLocation()
						local mouseRay = Camera:ViewportPointToRay(mouseLocation.X, mouseLocation.Y)
						local raycast = workspace:Raycast(mouseRay.Origin, mouseRay.Direction * (1 * 10 ^ 6), raycastParams)
						if raycast then
							local paramsTbl = {OBBPart}
							for _, gift in ipairs(tblOfGifts) do
								table.insert(paramsTbl, gift)
							end
							raycastParams.FilterDescendantsInstances = paramsTbl
							overlapParams.FilterDescendantsInstances = paramsTbl
							local region3 = workspace:GetPartBoundsInBox(OBBPart.CFrame, OBBPart.Size, overlapParams)
							if #region3 > 1 then
								for _, highlight in highlightTbl do
									hasCollisions2 = true
									highlight.OutlineColor = Color3.new(1,0,0)
								end
							else
								for _, highlight in highlightTbl do
									hasCollisions2 = false
									highlight.OutlineColor = Color3.new(0,1,0)
								end
							end
							local OBBPartCFrame = CrossProductNormalSurfaces(OBBPart, raycast)
							OBBPart.CFrame = OBBPartCFrame
							task.wait()
							giftCFrames2 = {}
							table.clear(giftCFrames2)
							for i, gift in ipairs(tblOfGifts) do
								gift = gift:FindFirstChild("Handle")
								if gift and tblGiftsObjSpace[i] then
									gift.CFrame = OBBPart.CFrame * tblGiftsObjSpace[i]
									table.insert(giftCFrames2, gift.CFrame)
								end	
							end
						end
					end
				end
				draggingConnection = RunService:BindToRenderStep("DBRS", Enum.RenderPriority.Camera.Value, draggingRenderStep)
			else
				RunService:UnbindFromRenderStep("DBRS")
				if highlightTbl then
					for _, highlight in highlightTbl do
						highlight:Destroy()
						highlight = nil
					end
				end
				if tblOfGifts then
					for _, gift in ipairs(tblOfGifts) do
						gift = gift:FindFirstChild("Handle")
						if gift then
							gift.CanCollide = true
							gift.Transparency = 0
							gift.Reflectance = 0
							gift.Material = Enum.Material.Plastic
						end	
					end
				end
				if not hasCollisions2 then
					if not isPlaced then
						isPlaced = not isPlaced
						REPlacementSystem2:FireServer(tblOfGifts, giftCFrames2, hasCollisions2)
						print(tblOfGifts, giftCFrames2)
						task.wait()
						isPlaced = not isPlaced
					end
				else
					OBBPart.CFrame = OBBPartCFStore
					for i, gift in ipairs(tblOfGifts) do
						if gift and tblGiftsCFStore[i] then
							gift:FindFirstChild("Handle").CFrame = tblGiftsCFStore[i]
						end	
					end
				end
				OBBPart.Size = Vector3.zero
				enableDraggingSystem = false
				tblOfGifts = {}
				table.clear(tblOfGifts)
				highlightTbl = {}
			end
		end
		enableDraggingSystem = not enableDraggingSystem
	end
end

local function cloningGifts(actionName, inputState, inputObject)
	if inputState == Enum.UserInputState.Begin then
		if (UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) or UserInputService:IsKeyDown(Enum.KeyCode.LeftControl)) then
			if UserInputService:IsKeyDown(Enum.KeyCode.C) then
				if #tblOfGifts > 0 then
					clipboardGifts = {}
					table.clear(clipboardGifts)
					clipboardObjSpace = {}
					table.clear(clipboardObjSpace)
					for _, gift in ipairs(tblOfGifts) do
						table.insert(clipboardGifts, gift)
						table.insert(clipboardObjSpace, OBBPart.CFrame:ToObjectSpace(gift:FindFirstChild("Handle").CFrame))
					end
				end
			end
			if UserInputService:IsKeyDown(Enum.KeyCode.V) then
				if OBBPart and #clipboardGifts > 0 and clipboardGifts then
					local mouseLocation = UserInputService:GetMouseLocation()
					local mouseRay = Camera:ViewportPointToRay(mouseLocation.X, mouseLocation.Y)
					local raycast = workspace:Raycast(mouseRay.Origin, mouseRay.Direction * (1 * 10 ^ 6), raycastParams)
					if raycast then
						clipboardCFrames = {}
						table.clear(clipboardCFrames)
						duplicateGiftsTbl = {}
						table.clear(duplicateGiftsTbl)
						for i, gift in ipairs(clipboardGifts) do
							local giftClone = gift:Clone()
							giftClone.Parent = giftFolder
							local gHandle = giftClone:FindFirstChild("Handle")
							gHandle.CanCollide = true
							gHandle.Transparency = 0
							gHandle.Reflectance = 0
							gHandle.Material = Enum.Material.Plastic
							for _, descendant in ipairs(gHandle:GetDescendants()) do
								if descendant:IsA("Highlight") then
									descendant:Destroy()
									descendant = nil
								end
							end
							local giftCloneCFrame = CrossProductNormalSurfaces(gHandle, raycast)
							gHandle.CFrame = giftCloneCFrame
							gHandle.CFrame = gHandle.CFrame * clipboardObjSpace[i]
							gHandle.CFrame = gHandle.CFrame:ToWorldSpace(CFrame.new(1*10^-3,1*10^-3 + OBBPart.Size.Y/2,1*10^-3))
							table.insert(clipboardCFrames, gHandle.CFrame)
							local newOverlapParamsTbl = {gHandle, OBBPart}
							for _, gift in ipairs(tblOfGifts) do
								table.insert(newOverlapParamsTbl, gift)
							end
							overlapParams.FilterDescendantsInstances = newOverlapParamsTbl
							local region3 = workspace:GetPartBoundsInBox(gHandle.CFrame, gHandle.Size, overlapParams)
							if #region3 > 0 then
								giftClone:Destroy()
								giftClone = nil
							else
								print(clipboardGifts, clipboardCFrames)
								cloningRE:FireServer(gift, gHandle.CFrame)
								task.wait()
								table.insert(duplicateGiftsTbl, giftClone)
							end
						end
						for _, duplicate in ipairs(duplicateGiftsTbl) do
							duplicate:Destroy()
							duplicate = nil
						end
					end
				end
			end
		end
	end
end

local function multiSelect(actionName, inputState, inputObject)
	if inputState == Enum.UserInputState.Begin then
		if inputObject.UserInputType == Enum.UserInputType.MouseButton1 then
			RunService:UnbindFromRenderStep("DBRS")
			if hasCollisions2 then
				OBBPart.CFrame = OBBPartCFStore
				for i, gift in ipairs(tblOfGifts) do
					if gift and tblGiftsCFStore[i] then
						gift:FindFirstChild("Handle").CFrame = tblGiftsCFStore[i]
					end	
				end
			end
			if highlightTbl then
				for _, highlight in highlightTbl do
					highlight:Destroy()
					highlight = nil
				end
			end
			if tblOfGifts then
				for _, gift in ipairs(tblOfGifts) do
					gift = gift:FindFirstChild("Handle")
					if gift then
						gift.CanCollide = true
						gift.Transparency = 0
						gift.Reflectance = 0
						gift.Material = Enum.Material.Plastic
					end	
				end
			end
			highlightTbl = {}
			OBBPart.Size = Vector3.zero
			arePartsSelected = false
			enableDraggingSystem = false
		end
	end
	if inputState == Enum.UserInputState.End then
		if inputObject.UserInputType == Enum.UserInputType.MouseButton1 then
			if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) or UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
				local mouseLocation = UserInputService:GetMouseLocation()
				local mouseRay = Camera:ViewportPointToRay(mouseLocation.X, mouseLocation.Y)
				if OBBPart then
					raycastParams.FilterDescendantsInstances = {OBBPart}
					local raycast = workspace:Raycast(mouseRay.Origin, mouseRay.Direction * (1 * 10 ^ 6), raycastParams)
					if raycast.Instance and raycast.Instance.Parent then
						if raycast.Instance.Parent:IsDescendantOf(giftFolder) then
							table.insert(tblOfGifts, raycast.Instance.Parent)
							local OBBPartSize, OBBPartCFrame = OverlappingBoundingBoxes(OBBPart.CFrame, tblOfGifts)
							OBBPart.Size = OBBPartSize
							OBBPart.CFrame = OBBPartCFrame
							if #tblOfGifts > 0 then
								table.insert(tblOfGifts, raycast.Instance.Parent)
								highlightTbl = createHighlights(tblOfGifts)
								if #giftCFrames2 > #tblOfGifts then
									for i = 1, #giftCFrames2 - #tblOfGifts do
										giftCFrames2[#giftCFrames2 - i] = nil
									end
								end
								tblGiftsObjSpace = {}
								table.clear(tblGiftsObjSpace)
								tblGiftsCFStore = {}
								table.clear(tblGiftsCFStore)
								OBBPartCFStore = OBBPartCFrame
								for i, gift in ipairs(tblOfGifts) do
									gift = gift:FindFirstChild("Handle")							
									if gift and OBBPart then
										table.insert(tblGiftsObjSpace, OBBPart.CFrame:ToObjectSpace(gift.CFrame))
										table.insert(tblGiftsCFStore, gift.CFrame)
									end	
								end
								arePartsSelected = true
							end
						else	
							OBBPart.Size = Vector3.zero
							tblOfGifts = {}
							table.clear(tblOfGifts)
							arePartsSelected = false
						end
					end
				end
			else
				OBBPart.Size = Vector3.zero
				tblOfGifts = {}
				table.clear(tblOfGifts)
				arePartsSelected = false
			end
		end
	end
end

